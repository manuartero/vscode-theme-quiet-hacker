  "tokenColors": [
    // ── Global Default ──
    {
      "scope": [],
      "settings": {
        "foreground": "#A0C8A0"
      }
    },
    // ── Comments ──
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#4a7a4a",
        "fontStyle": "italic"
      }
    },
    // ── Keywords & Control Flow ──
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#00802a"
      }
    },
    // ── Strings ──
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#C8C8C8"
      }
    },
    // ── Numbers & Constants ──
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character"
      ],
      "settings": {
        "foreground": "#00802a"
      }
    },
    // ── Functions ──
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#00802a"
      }
    },
    // ── Types & Classes ──
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#C8C8C8"
      }
    },
    // ── Variables & Parameters ──
    {
      "scope": [
        "variable",
        "variable.parameter",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#A0C8A0"
      }
    },
    // ── Operators & Punctuation ──
    {
      "scope": [
        "keyword.operator",
        "punctuation"
      ],
      "settings": {
        "foreground": "#888888"
      }
    },
    // ── Tags (HTML/JSX) ──
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#00802a"
      }
    },
    // ── Attributes (HTML/JSX) ──
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#C8C8C8"
      }
    },
    // ── CSS Properties ──
    {
      "scope": [
        "support.type.property-name.css",
        "meta.property-name"
      ],
      "settings": {
        "foreground": "#C8C8C8"
      }
    },
    // ── CSS Values ──
    {
      "scope": [
        "support.constant.property-value.css",
        "meta.property-value"
      ],
      "settings": {
        "foreground": "#C8C8C8"
      }
    },
    // ── Decorators / Annotations ──
    {
      "scope": [
        "meta.decorator",
        "meta.annotation"
      ],
      "settings": {
        "foreground": "#C8C8C8"
      }
    },
    // ── Markdown ──
    {
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#00802a",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#A0C8A0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#A0C8A0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#C8C8C8"
      }
    },
    {
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#00802a"
      }
    },
    // ── JSON Keys ──
    {
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#00802a"
      }
    },
    // ── Regex ──
    {
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#C8C8C8"
      }
    },
    // ── Invalid / Deprecated ──
    {
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#888888",
        "fontStyle": "strikethrough"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "function": "#00802a",
    "function.declaration": "#00802a",
    "variable": "#A0C8A0",
    "variable.readonly": "#A0C8A0",
    "property": "#C8C8C8",
    "parameter": "#A0C8A0",
    "type": "#C8C8C8",
    "class": "#C8C8C8",
    "interface": "#C8C8C8",
    "enum": "#C8C8C8",
    "enumMember": "#00802a",
    "namespace": "#C8C8C8",
    "keyword": "#00802a",
    "comment": "#4a7a4a",
    "string": "#C8C8C8",
    "number": "#00802a",
    "operator": "#888888",
    "decorator": "#C8C8C8"
  }
}
